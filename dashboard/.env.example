# ── Auth (NextAuth v5) ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# The user-facing ORIGIN (no /dashboard path). The auth routes live under
# /dashboard/api/auth via basePath in next.config.ts. Dev: the storefront origin.
# Prod: the storefront domain, e.g. https://mruk.co.tz
AUTH_URL="http://localhost:3000"

# ── Backend API (Fanisi Studio) ─────────────────────────────────────
# Server-side ONLY. Never expose as NEXT_PUBLIC_*. No trailing slash, no /api.
BACKEND_API_URL="https://fs-backend-tvk8.onrender.com"
# Request timeout in ms
BACKEND_API_TIMEOUT="15000"
# Tenant slug sent as x-tenant-slug on every backend call (selects the DB).
BACKEND_TENANT_SLUG="mr-uk"
# Dev-only: "true" enables the one-click mock admin login. Hard-disabled when
# NODE_ENV=production (see lib/auth.ts). Leave "false" for real backend auth.
DEV_AUTH_BYPASS="false"

# ── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000/dashboard"
