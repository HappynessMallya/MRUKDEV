# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=https://fs-backend-tvk8.onrender.com

# Tenant slug sent in the `x-tenant-slug` header on every API request.
# Registered on the backend as `mr-uk` (hyphenated) — NOT `mruk`.
NEXT_PUBLIC_TENANT_SLUG=mr-uk

# Catalog data source switch:
#   false (default) → local mock catalog in src/data/products.ts
#   true            → live API (src/lib/catalog.ts → Fanisi Studio API)
# Keep this false until the backend seeds the `mr-uk` tenant on the deployed
# instance (it currently 404s "Unknown tenant slug"). Flipping to true is the
# whole cutover — no component changes needed.
NEXT_PUBLIC_USE_API=false

# Local tenant-config fallback slug (used by src/lib/tenant.ts + proxy.ts to
# resolve the local mruk.json branding/CMS config — separate from the API slug).
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=mruk
